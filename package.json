{
  "name": "fnx-admin",
  "version": "1.0.1",
  "description": "Plataforma administrativa, transaccional y financiera multi-moneda",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "rebuild": "electron-rebuild -f -w sqlite3",
    "build-win": "electron-builder --win --x64",
    "tailwind": "npx tailwindcss -i ./src/renderer/styles/tailwind.css -o ./src/renderer/styles/output.css --watch",
    "tailwind-build": "npx tailwindcss -i ./src/renderer/styles/tailwind.css -o ./src/renderer/styles/output.css --minify",
    "postinstall": "electron-builder install-app-deps",
    "dev-mac": "npm run rebuild && npm start",
    "build-all": "npm run tailwind-build && npm run build-win",
    "git-release": "git add . && git commit -m \"Actualizacion y mejoras de estabilidad\" && git push"
  },
  "keywords": [
    "electron",
    "sqlite3",
    "finance",
    "admin"
  ],
  "author": "Fénix Admin S.A.",
  "license": "ISC",
  "dependencies": {
    "electron-updater": "^6.1.4",
    "googleapis": "^129.0.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "electron": "^28.2.0",
    "electron-builder": "^24.9.1",
    "electron-rebuild": "^3.2.9",
    "electron-reload": "^2.0.0-alpha.1",
    "tailwindcss": "^3.4.1"
  },
  "build": {
    "appId": "com.fnx.admin",
    "productName": "FENIX Suite",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "assets/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "assets/img/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Fenix Admin"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "username",
        "repo": "repo-name"
      }
    ]
  }
}
